# Anthropic API key — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — tune model behaviour
# AICORD_MODEL=claude-opus-4-6
# AICORD_MAX_TOKENS=8192
# AICORD_EFFORT=medium

# PORTGUARD configuration
PORTGUARD_MODEL=claude-opus-4-6
PORTGUARD_MAX_TOKENS=4096

# GitHub setup — only needed to run scripts/github-setup.js
# Create a token at github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
