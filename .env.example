# PortGuard environment variables
# Copy this file to .env and fill in your values.

# ---------------------------------------------------------------------------
# Database (required in production on Render)
# ---------------------------------------------------------------------------
# PostgreSQL connection string provided by Render's database add-on.
# When set, both auth data and pattern-learning data are stored in PostgreSQL.
# When NOT set, the app falls back to SQLite files for local development.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# Authentication (required in production)
# ---------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a random key is generated on each restart — all sessions lost on redeploy.
PORTGUARD_JWT_SECRET=your_64_char_hex_secret_here

# ---------------------------------------------------------------------------
# SQLite paths (local development only — ignored when DATABASE_URL is set)
# ---------------------------------------------------------------------------
PORTGUARD_AUTH_DB_PATH=portguard_auth.db
PORTGUARD_PATTERN_DB_PATH=portguard_patterns.db

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
PORTGUARD_PATTERN_LEARNING_ENABLED=true

# ---------------------------------------------------------------------------
# GitHub setup — only needed to run scripts/github-setup.js
# ---------------------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
